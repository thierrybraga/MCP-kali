# Kali MCP Pentest Environment Variables

# MCP Server Configuration
MCP_PORT=3000
MCP_HOST=0.0.0.0
MCP_ADVERTISED_URL=http://kali-pentest:3000
OPENCLAW_GATEWAY_URL=http://openclaw:18789
OPENCLAW_REGISTER_PATH=/api/mcp/register
OPENCLAW_HEARTBEAT_PATH=/api/mcp/heartbeat
OPENCLAW_HEARTBEAT_INTERVAL_MS=30000
OPENCLAW_CONNECT_TIMEOUT_MS=5000
OPENCLAW_REQUIRE_GATEWAY=true

# Timezone
TZ=America/Sao_Paulo

# Metasploit Database (se usar PostgreSQL externo)
POSTGRES_DB=msf
POSTGRES_USER=msf
POSTGRES_PASSWORD=change_me_to_strong_password

# Proxy Configuration (opcional)
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1

# Resource Limits
DOCKER_CPU_LIMIT=4
DOCKER_MEMORY_LIMIT=8G

# Network Configuration
NETWORK_SUBNET=172.25.0.0/16

# Report Settings
REPORT_DIR=/root/reports
AUTO_SAVE_REPORTS=true

# Security Settings
ENABLE_HOST_NETWORK=false
PRIVILEGED_MODE=true

# Logging
LOG_LEVEL=info
ENABLE_VERBOSE=false
