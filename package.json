{
  "name": "kali-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for Kali Linux Penetration Testing Tools",
  "keywords": [
    "hydra",
    "kali",
    "mcp",
    "nmap",
    "pentest",
    "security"
  ],
  "license": "MIT",
  "author": "Thierry Braga",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "bash scripts/run-all-tests.sh",
    "test:fast": "SKIP_SLOW=1 bash scripts/run-all-tests.sh",
    "test:health": "bash scripts/tests/test-health.sh",
    "test:skills": "bash scripts/tests/test-skills.sh",
    "test:security": "bash scripts/tests/test-security.sh",
    "test:pipeline": "bash scripts/tests/test-pipeline.sh",
    "test:nmap": "bash scripts/tests/test-nmap.sh",
    "test:web": "bash scripts/tests/test-web.sh",
    "test:tools": "bash scripts/tests/test-tools-generic.sh"
  },
  "dependencies": {
    "express": "^4.18.2",
    "openai": "^4.53.1",
    "undici": "^6.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
